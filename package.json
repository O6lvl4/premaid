{
  "name": "mermaid-pretty",
  "version": "0.1.0",
  "description": "Render beautiful Mermaid diagrams from the command line",
  "type": "module",
  "bin": {
    "mermaid-pretty": "dist/cli.js",
    "mmp": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc && chmod +x dist/cli.js",
    "dev": "tsx src/cli.ts",
